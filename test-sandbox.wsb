<Configuration>
  <!-- 
    OpenClaw Tray App — Windows Sandbox Test Config
    
    Usage: Double-click this file to launch a clean Windows Sandbox
    with the built tray app mapped in. The sandbox resets on close.
    
    Prerequisites:
      1. Enable Windows Sandbox: Enable-WindowsOptionalFeature -Online -FeatureName "Containers-DisposableClientVM"
      2. Build the app: .\build.ps1 -Project WinUI
      3. If testing against WSL gateway, set up port proxy (see setup-sandbox-network.ps1)
  -->
  <MappedFolders>
    <!-- Map build output (read-only) -->
    <MappedFolder>
      <HostFolder>C:\Users\mharsh\gt\openclaw\crew\mharsh\src\OpenClaw.Tray.WinUI\bin\Debug\net10.0-windows10.0.19041.0\win-x64</HostFolder>
      <SandboxFolder>C:\TestApp</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell -ExecutionPolicy Bypass -Command "
      $hostIp = (Get-NetRoute -DestinationPrefix '0.0.0.0/0' | Select-Object -First 1).NextHop;
      Write-Host '';
      Write-Host '  == OpenClaw Sandbox Test ==' -ForegroundColor Magenta;
      Write-Host '';
      Write-Host '  App:     C:\TestApp\OpenClaw.Tray.WinUI.exe' -ForegroundColor Cyan;
      Write-Host '  Host IP: ' -NoNewline; Write-Host $hostIp -ForegroundColor Yellow;
      Write-Host '  Gateway: ' -NoNewline; Write-Host ('ws://' + $hostIp + ':18789') -ForegroundColor Yellow;
      Write-Host '';
      Write-Host '  Steps:' -ForegroundColor White;
      Write-Host '    1. Run the app:  C:\TestApp\OpenClaw.Tray.WinUI.exe';
      Write-Host '    2. In onboarding, set Gateway URL to the address above';
      Write-Host '    3. Enter the bootstrap token from your WSL gateway';
      Write-Host '';
      Write-Host '  Close this sandbox window to reset everything.' -ForegroundColor Gray;
      Write-Host '';
    "</Command>
  </LogonCommand>
  <MemoryInMB>4096</MemoryInMB>
  <Networking>Default</Networking>
</Configuration>
