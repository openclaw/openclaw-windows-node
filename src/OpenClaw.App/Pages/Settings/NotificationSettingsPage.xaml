<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.App.Pages.Settings.NotificationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Notifications" Style="{StaticResource TitleTextBlockStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <ToggleSwitch x:Name="NotificationsToggle" Header="Show notifications"/>
                    <ComboBox x:Name="SoundCombo" Header="Sound" Width="200">
                        <ComboBoxItem Content="Default" Tag="Default"/>
                        <ComboBoxItem Content="None" Tag="None"/>
                        <ComboBoxItem Content="Subtle" Tag="Subtle"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Show notifications for:" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Spacing="4">
                        <CheckBox x:Name="NotifyHealthCb" Content="Health alerts"/>
                        <CheckBox x:Name="NotifyUrgentCb" Content="Urgent messages"/>
                        <CheckBox x:Name="NotifyReminderCb" Content="Reminders"/>
                        <CheckBox x:Name="NotifyEmailCb" Content="Email summaries"/>
                        <CheckBox x:Name="NotifyCalendarCb" Content="Calendar events"/>
                        <CheckBox x:Name="NotifyBuildCb" Content="Build notifications"/>
                        <CheckBox x:Name="NotifyStockCb" Content="Stock alerts"/>
                        <CheckBox x:Name="NotifyInfoCb" Content="Info messages"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave" HorizontalAlignment="Right"/>
        </StackPanel>
    </ScrollViewer>
</Page>
