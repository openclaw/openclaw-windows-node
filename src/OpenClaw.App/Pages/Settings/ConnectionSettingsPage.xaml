<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.App.Pages.Settings.ConnectionSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Connection" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Topology preset buttons -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Gateway topology" FontWeight="SemiBold"/>
                    <TextBlock Text="Choose the setup that matches where your OpenClaw gateway runs."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="Use Local Gateway" Click="OnUseLocalGateway" HorizontalAlignment="Stretch"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="Use WSL Gateway" Click="OnUseWslGateway" HorizontalAlignment="Stretch"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="Use SSH Tunnel" Click="OnUseSshTunnel" HorizontalAlignment="Stretch"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="Remote / Tailscale" Click="OnUseRemoteGateway" HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SSH Tunnel -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <ToggleSwitch x:Name="SshTunnelToggle" Header="Connect through SSH tunnel" Toggled="OnSshTunnelToggled"/>
                    <StackPanel x:Name="SshTunnelPanel" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="When enabled, the app connects through ws://127.0.0.1:&lt;local-port&gt; and creates an SSH forward to the remote gateway host."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshUserBox" Grid.Column="0" Header="SSH User" PlaceholderText="user"/>
                            <TextBox x:Name="SshHostBox" Grid.Column="1" Header="SSH Host" PlaceholderText="machine-name or IP"/>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshRemotePortBox" Grid.Column="0" Header="Remote Gateway Port" PlaceholderText="18789"/>
                            <TextBox x:Name="SshLocalPortBox" Grid.Column="1" Header="Local Forward Port" PlaceholderText="18789"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Gateway URL and Token -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBox x:Name="GatewayUrlBox" Header="Gateway URL" PlaceholderText="ws://localhost:18789 or wss://host.tailnet.ts.net"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PasswordBox x:Name="TokenBox" Header="Token" PlaceholderText="Gateway auth token" Width="300"/>
                        <Button x:Name="TestConnectionButton" Content="Test" VerticalAlignment="Bottom" Click="OnTestConnection"/>
                    </StackPanel>
                    <TextBlock x:Name="ConnectionStatusLabel" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave" HorizontalAlignment="Right"/>
        </StackPanel>
    </ScrollViewer>
</Page>
