<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.SetupEngine.UI.Pages.AdvancedSetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Disabled">

    <Grid Padding="48,28,48,24" RowDefinitions="Auto,*,Auto">

        <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center">
            <Image Source="ms-appx:///OpenClaw.SetupEngine.UI/Assets/Setup/OpenClawMascot.png"
                   Width="44" Height="44" HorizontalAlignment="Center"
                   AutomationProperties.AccessibilityView="Raw" />
            <TextBlock Text="Connect to an existing gateway"
                       Style="{StaticResource TitleTextBlockStyle}"
                       TextAlignment="Center" HorizontalAlignment="Center" />
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="520"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Text="We'll open Companion Settings next — nothing gets installed. Here's what you'll do there:" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="16" MaxWidth="520" VerticalAlignment="Top"
                    HorizontalAlignment="Stretch" Margin="0,24,0,0">

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <FontIcon Grid.Column="0" Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="20" VerticalAlignment="Top" IsTextScaleFactorEnabled="False"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Add a gateway" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="In Connection, choose Add a gateway, then pick how to connect: Setup code or Direct (URL + token)." />
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <FontIcon Grid.Column="0" Glyph="&#xE774;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="20" VerticalAlignment="Top" IsTextScaleFactorEnabled="False"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Point it at your gateway" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Connect to a gateway running here, on another PC, or remote — for example ws://host.local:18790." />
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <FontIcon Grid.Column="0" Glyph="&#xE772;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="20" VerticalAlignment="Top" IsTextScaleFactorEnabled="False"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Pair this device" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Paste a setup code from the gateway host, or your shared token, so the gateway trusts this PC." />
                </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <FontIcon Grid.Column="0" Glyph="&#xE72E;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          FontSize="20" VerticalAlignment="Top" IsTextScaleFactorEnabled="False"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Optional: SSH tunnel" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="If your gateway isn't directly reachable, any method can tunnel over SSH." />
                </StackPanel>
            </Grid>

        </StackPanel>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
            <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsTabStop="False" AutomationProperties.Name="Step 2 of 6">
                <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupInactiveDotBrush}" />
                <Border Width="20" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupIndicatorAccentBrush}" />
                <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupInactiveDotBrush}" />
                <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupInactiveDotBrush}" />
                <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupInactiveDotBrush}" />
                <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{ThemeResource SetupInactiveDotBrush}" />
            </StackPanel>
            <Button x:Name="BackButton" Grid.Column="0" Content="Back"
                    Height="44" MinWidth="96" HorizontalAlignment="Left"
                    Click="Back_Click" />
            <Button x:Name="OpenConnectionButton" Grid.Column="1" Content="Open Companion Settings"
                    Height="44" MinWidth="200" HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OpenConnection_Click" />
        </Grid>
    </Grid>
</Page>
