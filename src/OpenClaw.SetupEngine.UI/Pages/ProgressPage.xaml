<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.SetupEngine.UI.Pages.ProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Disabled">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="56,24,56,0" Spacing="4">
            <Image Source="ms-appx:///OpenClaw.SetupEngine.UI/Assets/Setup/Lobster.png" Width="44" Height="44"
                   HorizontalAlignment="Center" Margin="0,0,0,2" />
            <TextBlock Text="Setting up locally"
                       FontSize="26" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SubtitleText"
                       FontSize="13" Opacity="0.6"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Step rows -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StepsPanel"
                        Padding="56,24,56,12" Spacing="18"
                        VerticalAlignment="Top">
                <!-- Populated in code-behind -->
            </StackPanel>
        </ScrollViewer>

        <!-- Log viewer (bottom panel) -->
        <Grid Grid.Row="2" Padding="24,0,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="LogPanel" Grid.Row="0"
                    CornerRadius="6" Padding="12,8,12,8"
                    Height="200" Visibility="Collapsed"
                    Margin="0,0,0,8">
                <ScrollViewer x:Name="LogScroller"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextWrapping="NoWrap"
                               IsTextSelectionEnabled="True" />
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button x:Name="OpenLogButton"
                        Grid.Column="1"
                        Content="Open log" FontSize="12"
                        Visibility="Collapsed"
                        Click="OpenLog_Click"
                        Padding="8,4,8,4" />
                <Button x:Name="LogToggleButton"
                        Grid.Column="2"
                        Content="Show logs ▲" FontSize="12"
                        Click="LogToggle_Click"
                        Padding="8,4,8,4" />
            </Grid>
        </Grid>

    </Grid>
</Page>
