<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.SetupEngine.UI.Pages.CompletePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Disabled">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="480" Padding="56,40,56,40" Spacing="16">

        <!-- Party popper / Error icon -->
        <Image x:Name="ResultImage"
               Width="120" Height="120"
               HorizontalAlignment="Center" />

        <!-- Title -->
        <TextBlock x:Name="TitleText"
                   FontSize="32" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <!-- Subtitle -->
        <TextBlock x:Name="SubtitleText"
                   FontSize="14" Opacity="0.6"
                   HorizontalAlignment="Center" />

        <!-- Elapsed time -->
        <TextBlock x:Name="ElapsedText"
                   FontSize="13" Opacity="0.5"
                   HorizontalAlignment="Center" />

        <!-- Spacer -->
        <Border Height="24" />

        <!-- Launch Tray button -->
        <Button x:Name="LaunchButton"
                Content="Launch OpenClaw Tray"
                HorizontalAlignment="Stretch"
                Height="44" FontSize="15" FontWeight="SemiBold"
                Click="LaunchButton_Click">
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackground" Color="#60C8F8" />
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#52B0DA" />
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#469BBC" />
                <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
            </Button.Resources>
        </Button>

        <!-- View log link -->
        <HyperlinkButton x:Name="ViewLogLink"
                         Content="View full log"
                         HorizontalAlignment="Center"
                         FontSize="13"
                         Click="ViewLog_Click" />

    </StackPanel>
</Page>
