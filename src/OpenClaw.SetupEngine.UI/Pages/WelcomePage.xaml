<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClaw.SetupEngine.UI.Pages.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Disabled">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Padding="56,48,56,48" Spacing="20">

            <!-- Logo -->
            <Image Source="ms-appx:///Assets/Setup/Lobster.png"
                   Width="170" Height="170"
                   HorizontalAlignment="Center" />

            <!-- Title -->
            <TextBlock Text="Get started with OpenClaw"
                       FontSize="28" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <!-- Description -->
            <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                       FontSize="14" Opacity="0.7" MaxWidth="440"
                       Text="OpenClaw lets agents run commands, read and write files, and capture screenshots on this PC. Only set it up on a computer you trust." />

            <!-- Info card -->
            <Border x:Name="InfoCard" CornerRadius="8" Padding="16,14,16,14">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border Width="20" Height="20" CornerRadius="10"
                            Background="#60C8F8" VerticalAlignment="Top">
                        <TextBlock Text="i" FontSize="12" FontWeight="SemiBold"
                                   Foreground="Black"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="InfoText" Grid.Column="1" TextWrapping="Wrap" FontSize="13"
                               Opacity="0.8" />
                </Grid>
            </Border>

            <!-- Start button -->
            <Button x:Name="StartButton"
                    Content="Set up locally"
                    HorizontalAlignment="Stretch"
                    Height="44" FontSize="15" FontWeight="SemiBold"
                    Click="StartButton_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#60C8F8" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#52B0DA" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#469BBC" />
                    <SolidColorBrush x:Key="ButtonForeground" Color="Black" />
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Black" />
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="Black" />
                </Button.Resources>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>
