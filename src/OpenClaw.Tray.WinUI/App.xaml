<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="OpenClawTray.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Setup-only indicator brushes. They must live at App scope (not just in
                 SetupWindow's element resources) because the setup pages resolve them via
                 {ThemeResource} at page-load, before they attach to the setup window's
                 resource scope. They alias NATIVE system resources - the active indicator
                 follows the user's Windows accent, the inactive dot is a native neutral -
                 so onboarding showcases the user's chosen system colors. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="SetupIndicatorAccentBrush" Color="{ThemeResource SystemAccentColorLight2}" />
                    <SolidColorBrush x:Key="SetupInactiveDotBrush" Color="{ThemeResource ControlStrongFillColorDefault}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SetupIndicatorAccentBrush" Color="{ThemeResource SystemAccentColorDark1}" />
                    <SolidColorBrush x:Key="SetupInactiveDotBrush" Color="{ThemeResource ControlStrongFillColorDefault}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="SetupIndicatorAccentBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="SetupInactiveDotBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Hub NavigationView selection indicator follows the user's Windows accent. -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground"
                             Color="{ThemeResource SystemAccentColor}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
