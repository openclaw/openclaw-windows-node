<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="OpenClawTray.Windows.HubWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="OpenClaw"
    MinWidth="600" MinHeight="400">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" PreviewKeyDown="OnRootPreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="12,0,140,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon + Title -->
            <TextBlock Grid.Column="0" Text="🦞" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="1" x:Name="TitleText" Text="OpenClaw"
                       FontSize="12" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"/>

            <!-- Search box (centered in remaining space) -->
            <AutoSuggestBox Grid.Column="2" x:Name="TitleSearchBox"
                            PlaceholderText="Search commands… (Ctrl+K)"
                            QueryIcon="Find"
                            HorizontalAlignment="Center"
                            Width="280" VerticalAlignment="Center"
                            Margin="12,0,12,0"
                            TextChanged="OnSearchTextChanged"
                            SuggestionChosen="OnSearchSuggestionChosen"
                            QuerySubmitted="OnSearchQuerySubmitted">
                <AutoSuggestBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,4">
                            <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Spacing="0">
                                <TextBlock Text="{Binding Title}" FontSize="12"/>
                                <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </AutoSuggestBox.ItemTemplate>
            </AutoSuggestBox>

            <!-- Status indicator on the right -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse x:Name="TitleStatusDot" Width="8" Height="8" VerticalAlignment="Center"
                         Fill="Gray"/>
                <TextBlock x:Name="TitleStatusText" Text="Disconnected"
                           FontSize="11" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <NavigationView Grid.Row="1"
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Auto"
            SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="home" Content="Home">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="chat" Content="Chat">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8BD;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemSeparator/>

            <NavigationViewItemHeader Content="Gateway"/>
            <NavigationViewItem Tag="connection" Content="Connection">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE839;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <!-- Agents parent — children built dynamically -->
            <NavigationViewItem x:Name="AgentsNavItem" Content="Agents" SelectsOnInvoked="False" IsExpanded="True">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE99A;"/></NavigationViewItem.Icon>
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem x:Name="DefaultAgentNavItem" Content="main" Tag="agent:main" IsExpanded="True">
                        <NavigationViewItem.Icon><FontIcon Glyph="&#xE99A;"/></NavigationViewItem.Icon>
                        <NavigationViewItem.MenuItems>
                            <NavigationViewItem Tag="agent:main:sessions" Content="Sessions">
                                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F2;"/></NavigationViewItem.Icon>
                            </NavigationViewItem>
                            <NavigationViewItem Tag="agent:main:agentevents" Content="Agent Events">
                                <NavigationViewItem.Icon><FontIcon Glyph="&#xE943;"/></NavigationViewItem.Icon>
                            </NavigationViewItem>
                            <NavigationViewItem Tag="agent:main:skills" Content="Skills">
                                <NavigationViewItem.Icon><FontIcon Glyph="&#xE945;"/></NavigationViewItem.Icon>
                            </NavigationViewItem>
                            <NavigationViewItem Tag="agent:main:workspace" Content="Workspace">
                                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B7;"/></NavigationViewItem.Icon>
                            </NavigationViewItem>
                        </NavigationViewItem.MenuItems>
                    </NavigationViewItem>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
            <NavigationViewItem Tag="channels" Content="Channels">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xEC05;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="bindings" Content="Bindings">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8AD;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="instances" Content="Instances">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE968;"/></NavigationViewItem.Icon>
                <NavigationViewItem.MenuItems>
                    <NavigationViewItem Tag="nodes" Content="Nodes">
                        <NavigationViewItem.Icon><FontIcon Glyph="&#xE977;"/></NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationViewItem.MenuItems>
            </NavigationViewItem>
            <NavigationViewItem Tag="config" Content="Config">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE90F;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="usage" Content="Usage">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="cron" Content="Cron">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE787;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemSeparator/>

            <NavigationViewItemHeader Content="This Computer"/>
            <NavigationViewItem Tag="capabilities" Content="Capabilities">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE964;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="settings" Content="Settings">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="permissions" Content="Permissions">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D7;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="activity" Content="Activity">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xEA95;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Tag="debug" Content="Debug">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xEBE8;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="info" Content="Info">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE946;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition/>
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </NavigationView>

    </Grid>
</winex:WindowEx>
