<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="OpenClawTray.Windows.StatusDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="Status — OpenClaw Tray">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="16" MaxWidth="520">
            
            <!-- Status Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="StatusIcon" Glyph="&#xE8FB;" FontSize="32"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                <StackPanel>
                    <TextBlock x:Name="StatusText" x:Uid="StatusConnectedText" Text="Connected" 
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="LastCheckText" Text="Last check: --"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Gateway Topology Section -->
            <StackPanel x:Name="GatewayTopologySection" AutomationProperties.AutomationId="CommandCenterGatewayTopologySection" Spacing="8">
                <TextBlock x:Uid="StatusGatewayTopologyHeader" Text="GATEWAY TOPOLOGY" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Grid Padding="12" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Kind:"/>
                    <TextBlock x:Name="GatewayKindText" Grid.Row="0" Grid.Column="1"
                               Text="Unknown" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="URL:"/>
                    <TextBlock x:Name="GatewayUrlText" Grid.Row="1" Grid.Column="1"
                               Text="n/a" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Transport:"/>
                    <TextBlock x:Name="GatewayTransportText" Grid.Row="2" Grid.Column="1"
                               Text="unknown" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TunnelLabelText" Grid.Row="3" Grid.Column="0" Text="Tunnel:" Visibility="Collapsed"/>
                    <TextBlock x:Name="TunnelDetailText" Grid.Row="3" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayVersionLabelText" Grid.Row="4" Grid.Column="0" Text="Version:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayVersionText" Grid.Row="4" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayUptimeLabelText" Grid.Row="5" Grid.Column="0" Text="Uptime:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayUptimeText" Grid.Row="5" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayStateLabelText" Grid.Row="6" Grid.Column="0" Text="State:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayStateText" Grid.Row="6" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayRuntimeLabelText" Grid.Row="7" Grid.Column="0" Text="Process:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayRuntimeText" Grid.Row="7" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"
                               AutomationProperties.AutomationId="CommandCenterGatewayRuntimeText"/>
                </Grid>
                <TextBlock x:Name="GatewayDetailText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Overview Section -->
            <StackPanel x:Name="OverviewSection" AutomationProperties.AutomationId="CommandCenterOverviewSection" Spacing="8">
                <TextBlock Text="COMMAND CENTER" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Grid Padding="12" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="OverviewChannelsText" Grid.Row="0" Grid.Column="0" Text="Channels: 0"/>
                    <TextBlock x:Name="OverviewSessionsText" Grid.Row="0" Grid.Column="1" Text="Sessions: 0"/>
                    <TextBlock x:Name="OverviewNodesText" Grid.Row="1" Grid.Column="0" Text="Nodes: 0"/>
                    <TextBlock x:Name="OverviewWarningsText" Grid.Row="1" Grid.Column="1" Text="Warnings: 0"/>
                </Grid>
            </StackPanel>

            <!-- Support / Debug Actions Section -->
            <StackPanel x:Name="SupportActionsSection" AutomationProperties.AutomationId="CommandCenterSupportActionsSection" Spacing="8">
                <TextBlock x:Uid="StatusSupportDebugHeader" Text="SUPPORT &amp; DEBUG" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Grid Padding="12" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="StatusOpenLogsButton"
                                Content="Open Logs"
                                Click="OnOpenLogsFolder"
                                AutomationProperties.AutomationId="CommandCenterOpenLogsButton"/>
                        <Button x:Uid="StatusOpenConfigButton"
                                Content="Open Config"
                                Click="OnOpenConfigFolder"
                                AutomationProperties.AutomationId="CommandCenterOpenConfigButton"/>
                        <Button x:Uid="StatusRefreshHealthButton"
                                Content="Refresh Health"
                                Click="OnRefresh"
                                AutomationProperties.AutomationId="CommandCenterRefreshHealthButton"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="StatusOpenDiagnosticsJsonlButton"
                                Content="Open Diagnostics JSONL"
                                Click="OnOpenDiagnosticsFolder"
                                AutomationProperties.AutomationId="CommandCenterOpenDiagnosticsButton"/>
                        <Button x:Uid="StatusCopySupportContextButton"
                                Content="Copy Support Context"
                                Click="OnCopySupportContext"
                                AutomationProperties.AutomationId="CommandCenterCopySupportContextButton"/>
                        <Button x:Name="RestartSshTunnelButton"
                                x:Uid="StatusRestartSshTunnelButton"
                                Content="Restart SSH Tunnel"
                                Click="OnRestartSshTunnel"
                                AutomationProperties.AutomationId="CommandCenterRestartSshTunnelButton"
                                Visibility="Collapsed"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="StatusCopyBrowserSetupButton"
                                Content="Copy Browser Setup"
                                Click="OnCopyBrowserSetup"
                                AutomationProperties.AutomationId="CommandCenterCopyBrowserSetupButton"/>
                        <Button x:Uid="StatusCopyDebugBundleButton"
                                Content="Copy Debug Bundle"
                                Click="OnCopyDebugBundle"
                                AutomationProperties.AutomationId="CommandCenterCopyDebugBundleButton"/>
                        <Button x:Uid="StatusCheckUpdatesButton"
                                Content="Check Updates"
                                Click="OnCheckUpdates"
                                AutomationProperties.AutomationId="CommandCenterCheckUpdatesButton"/>
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatusText"
                               Grid.Row="3"
                               AutomationProperties.AutomationId="CommandCenterUpdateStatusText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
                <TextBlock Text="These actions only open local folders or copy metadata. They do not include tokens, command arguments, screenshots, recordings, camera data, or payloads."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Diagnostics Section -->
            <StackPanel x:Name="WarningsSection" AutomationProperties.AutomationId="CommandCenterDiagnosticsSection" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="DIAGNOSTICS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <ItemsControl x:Name="WarningsList" AutomationProperties.AutomationId="CommandCenterWarningsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                     <TextBlock Text="{Binding Detail}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextWrapping="Wrap"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                     <Button Content="{Binding RepairAction}"
                                             Tag="{Binding CopyText}"
                                             Visibility="{Binding CopyVisibility}"
                                             Click="OnCopyWarningFix"
                                             AutomationProperties.AutomationId="CommandCenterCopyWarningFixButton"
                                             Margin="0,8,0,0"
                                             HorizontalAlignment="Left"/>
                                 </StackPanel>
                             </Grid>
                         </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Port Diagnostics Section -->
            <StackPanel x:Name="PortDiagnosticsSection" AutomationProperties.AutomationId="CommandCenterPortDiagnosticsSection" Spacing="8" Visibility="Collapsed">
                <TextBlock x:Uid="StatusPortDiagnosticsHeader" Text="PORT DIAGNOSTICS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Button x:Uid="StatusCopyPortDiagnosticsButton"
                        Content="Copy Port Diagnostics"
                        HorizontalAlignment="Left"
                        Click="OnCopyPortDiagnostics"
                        AutomationProperties.AutomationId="CommandCenterCopyPortDiagnosticsButton"/>
                <ItemsControl x:Name="PortDiagnosticsList" AutomationProperties.AutomationId="CommandCenterPortDiagnosticsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Purpose}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusText}" Grid.Column="2"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Permissions Section -->
            <StackPanel x:Name="PermissionsSection" AutomationProperties.AutomationId="CommandCenterPermissionsSection" Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="StatusPermissionsHeader"
                               Text="PERMISSIONS"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontWeight="Bold"/>
                    <Button x:Uid="StatusCopyButton"
                            Grid.Column="1"
                            Content="Copy"
                            Click="OnCopyCapabilityDiagnostics"
                            AutomationProperties.AutomationId="CommandCenterCopyCapabilityDiagnosticsButton"/>
                </Grid>
                <ItemsControl x:Name="PermissionsList" AutomationProperties.AutomationId="CommandCenterPermissionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button x:Uid="StatusSettingsButton"
                                        Grid.Column="2"
                                        Content="Settings"
                                        Tag="{Binding SettingsUri}"
                                        Click="OnOpenPermissionSettings"
                                        AutomationProperties.AutomationId="CommandCenterOpenPermissionSettingsButton"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Usage Section -->
            <StackPanel x:Name="UsageSection" AutomationProperties.AutomationId="CommandCenterUsageSection" Spacing="8">
                <TextBlock x:Uid="StatusUsageHeader" Text="USAGE" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                
                <Grid ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Uid="StatusCostLabel" Grid.Row="0" Grid.Column="0" Text="Cost (window):"/>
                    <TextBlock x:Name="TodayCostText" Grid.Row="0" Grid.Column="1" 
                               Text="$0.00" FontWeight="SemiBold"/>
                    
                    <TextBlock x:Uid="StatusRequestsLabel" Grid.Row="1" Grid.Column="0" Text="Requests / Tokens:"/>
                    <TextBlock x:Name="TodayRequestsText" Grid.Row="1" Grid.Column="1" 
                               Text="0 / 0" FontWeight="SemiBold"/>

                    <TextBlock x:Uid="StatusProvidersLabel" Grid.Row="2" Grid.Column="0" Text="Providers:"/>
                    <TextBlock x:Name="ProviderSummaryText" Grid.Row="2" Grid.Column="1"
                               Text="n/a" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Grid>

                <StackPanel x:Name="CostTrendSection"
                            AutomationProperties.AutomationId="CommandCenterCostTrendSection"
                            Spacing="6"
                            Visibility="Collapsed">
                    <TextBlock x:Uid="StatusCostTrendHeader"
                               Text="30-DAY COST TREND"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontWeight="SemiBold"/>
                    <ItemsControl x:Name="CostTrendList"
                                  AutomationProperties.AutomationId="CommandCenterCostTrendList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Padding="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DateLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <Grid Grid.Column="1" Height="10" VerticalAlignment="Center"
                                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Border Width="{Binding BarWidth}"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"/>
                                    </Grid>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Sessions Section -->
            <StackPanel x:Name="SessionsSection" AutomationProperties.AutomationId="CommandCenterSessionsSection" Spacing="8">
                <TextBlock x:Uid="StatusSessionsHeader" Text="ACTIVE SESSIONS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                
                <ItemsControl x:Name="SessionsList" AutomationProperties.AutomationId="CommandCenterSessionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="💬" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Channel}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LastMessage}" 
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock x:Name="NoSessionsText" x:Uid="StatusNoSessions" Text="No active sessions"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Channels Section -->
            <StackPanel x:Name="ChannelsSection" AutomationProperties.AutomationId="CommandCenterChannelsSection" Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="StatusChannelsHeader" Text="CHANNELS" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                    <Button x:Uid="StatusCopyButton"
                            Grid.Column="1"
                            Content="Copy"
                            Click="OnCopyChannelSummary"
                            AutomationProperties.AutomationId="CommandCenterCopyChannelSummaryButton"/>
                </Grid>
                <TextBlock x:Name="ChannelSummaryText"
                           AutomationProperties.AutomationId="CommandCenterChannelSummaryText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                
                <ItemsControl x:Name="ChannelsList" AutomationProperties.AutomationId="CommandCenterChannelsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="4">
                                    <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right"/>
                                    <Button Content="{Binding ActionText}"
                                            Tag="{Binding Name}"
                                            IsEnabled="{Binding ActionEnabled}"
                                            Click="OnToggleChannel"
                                            AutomationProperties.AutomationId="CommandCenterToggleChannelButton"/>
                                    <Button x:Uid="StatusOpenButton"
                                            Content="Open"
                                            Tag="{Binding DashboardPath}"
                                            Click="OnOpenDashboardPath"
                                            AutomationProperties.AutomationId="CommandCenterOpenChannelDashboardButton"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Extensibility Section -->
            <StackPanel x:Name="ExtensibilitySection"
                        AutomationProperties.AutomationId="CommandCenterExtensibilitySection"
                        Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="StatusExtensibilityHeader"
                               Text="EXTENSIBILITY"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontWeight="Bold"/>
                    <Button x:Uid="StatusCopyButton"
                            Grid.Column="1"
                            Content="Copy"
                            Click="OnCopyExtensibilitySummary"
                            AutomationProperties.AutomationId="CommandCenterCopyExtensibilitySummaryButton"/>
                </Grid>
                <TextBlock x:Uid="StatusExtensibilityDescription"
                           Text="Channel setup, skills, and scheduled automations are gateway-owned surfaces. Use these links when the connected gateway exposes the matching dashboard pages."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock x:Uid="StatusChannelSetupTitle" Text="Channel setup / schemas" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="StatusChannelSetupDescription"
                                   Text="Open channel setup for schema-driven auth, QR, login, and dashboard flows where available."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Uid="StatusOpenButton"
                            Grid.Row="0" Grid.Column="1"
                            Content="Open"
                            Tag="channels"
                            Click="OnOpenDashboardPath"
                            AutomationProperties.AutomationId="CommandCenterOpenChannelsDashboardButton"/>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock x:Uid="StatusSkillsTitle" Text="Skills" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="StatusSkillsDescription"
                                   Text="Open gateway skills configuration when the connected gateway supports it."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Uid="StatusOpenButton"
                            Grid.Row="1" Grid.Column="1"
                            Content="Open"
                            Tag="skills"
                            Click="OnOpenDashboardPath"
                            AutomationProperties.AutomationId="CommandCenterOpenSkillsDashboardButton"/>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock x:Uid="StatusCronTitle" Text="Cron / schedules" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="StatusCronDescription"
                                   Text="Open scheduled automation controls when the connected gateway supports them."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Uid="StatusOpenButton"
                            Grid.Row="2" Grid.Column="1"
                            Content="Open"
                            Tag="cron"
                            Click="OnOpenDashboardPath"
                            AutomationProperties.AutomationId="CommandCenterOpenCronDashboardButton"/>
                </Grid>
            </StackPanel>

            <!-- Nodes Section -->
            <StackPanel x:Name="NodesSection" AutomationProperties.AutomationId="CommandCenterNodesSection" Spacing="8">
                <TextBlock x:Uid="StatusNodesHeader" Text="NODES" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Button x:Uid="StatusCopyNodeInventoryButton"
                        Content="Copy Node Inventory"
                        HorizontalAlignment="Left"
                        Click="OnCopyNodeInventory"
                        AutomationProperties.AutomationId="CommandCenterCopyNodeInventoryButton"/>
                <ItemsControl x:Name="NodesList" AutomationProperties.AutomationId="CommandCenterNodesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CommandText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button x:Uid="StatusCopyButton"
                                        Grid.Column="2"
                                        Content="Copy"
                                        Tag="{Binding SummaryText}"
                                        Click="OnCopyNodeSummary"
                                        AutomationProperties.AutomationId="CommandCenterCopyNodeSummaryButton"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="NoNodesText" x:Uid="StatusNoNodes" Text="No nodes reported"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Recent Activity Section -->
            <StackPanel x:Name="RecentActivitySection"
                        AutomationProperties.AutomationId="CommandCenterRecentActivitySection"
                        Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Uid="StatusRecentActivityHeader"
                               Text="RECENT ACTIVITY"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                               FontWeight="Bold"/>
                    <Button x:Uid="StatusOpenStreamButton"
                            Grid.Column="1"
                            Content="Open Stream"
                            Click="OnOpenActivityStream"
                            AutomationProperties.AutomationId="CommandCenterOpenActivityStreamButton"/>
                    <Button x:Uid="StatusCopyButton"
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Copy"
                            Click="OnCopyActivitySummary"
                            AutomationProperties.AutomationId="CommandCenterCopyActivitySummaryButton"/>
                </Grid>
                <ItemsControl x:Name="RecentActivityList"
                              AutomationProperties.AutomationId="CommandCenterRecentActivityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TimeAgo}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Category}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="NoRecentActivityText"
                           x:Uid="StatusNoRecentActivity"
                           Text="No recent activity"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Refresh Button -->
            <Button x:Name="RefreshButton" x:Uid="StatusRefreshButton" AutomationProperties.AutomationId="RefreshButton" Content="Refresh" Click="OnRefresh" HorizontalAlignment="Center"/>
            
        </StackPanel>
    </ScrollViewer>
</winex:WindowEx>

