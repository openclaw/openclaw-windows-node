<?xml version="1.0" encoding="utf-8"?>
<winex:WindowEx
    x:Class="OpenClawTray.Windows.StatusDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:winex="using:WinUIEx"
    Title="Status — OpenClaw Tray">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="16" MaxWidth="520">
            
            <!-- Status Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon x:Name="StatusIcon" Glyph="&#xE8FB;" FontSize="32"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                <StackPanel>
                    <TextBlock x:Name="StatusText" x:Uid="StatusConnectedText" Text="Connected" 
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:Name="LastCheckText" Text="Last check: --"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Gateway Topology Section -->
            <StackPanel x:Name="GatewayTopologySection" AutomationProperties.AutomationId="CommandCenterGatewayTopologySection" Spacing="8">
                <TextBlock Text="GATEWAY TOPOLOGY" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Grid Padding="12" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Kind:"/>
                    <TextBlock x:Name="GatewayKindText" Grid.Row="0" Grid.Column="1"
                               Text="Unknown" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="URL:"/>
                    <TextBlock x:Name="GatewayUrlText" Grid.Row="1" Grid.Column="1"
                               Text="n/a" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Transport:"/>
                    <TextBlock x:Name="GatewayTransportText" Grid.Row="2" Grid.Column="1"
                               Text="unknown" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TunnelLabelText" Grid.Row="3" Grid.Column="0" Text="Tunnel:" Visibility="Collapsed"/>
                    <TextBlock x:Name="TunnelDetailText" Grid.Row="3" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayVersionLabelText" Grid.Row="4" Grid.Column="0" Text="Version:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayVersionText" Grid.Row="4" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayUptimeLabelText" Grid.Row="5" Grid.Column="0" Text="Uptime:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayUptimeText" Grid.Row="5" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayStateLabelText" Grid.Row="6" Grid.Column="0" Text="State:" Visibility="Collapsed"/>
                    <TextBlock x:Name="GatewayStateText" Grid.Row="6" Grid.Column="1"
                               Text="" TextWrapping="Wrap" Visibility="Collapsed"/>
                </Grid>
                <TextBlock x:Name="GatewayDetailText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Overview Section -->
            <StackPanel x:Name="OverviewSection" AutomationProperties.AutomationId="CommandCenterOverviewSection" Spacing="8">
                <TextBlock Text="COMMAND CENTER" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <Grid Padding="12" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="OverviewChannelsText" Grid.Row="0" Grid.Column="0" Text="Channels: 0"/>
                    <TextBlock x:Name="OverviewSessionsText" Grid.Row="0" Grid.Column="1" Text="Sessions: 0"/>
                    <TextBlock x:Name="OverviewNodesText" Grid.Row="1" Grid.Column="0" Text="Nodes: 0"/>
                    <TextBlock x:Name="OverviewWarningsText" Grid.Row="1" Grid.Column="1" Text="Warnings: 0"/>
                </Grid>
            </StackPanel>

            <!-- Diagnostics Section -->
            <StackPanel x:Name="WarningsSection" AutomationProperties.AutomationId="CommandCenterDiagnosticsSection" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="DIAGNOSTICS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <ItemsControl x:Name="WarningsList" AutomationProperties.AutomationId="CommandCenterWarningsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Icon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                     <TextBlock Text="{Binding Detail}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextWrapping="Wrap"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                     <Button Content="{Binding RepairAction}"
                                             Tag="{Binding CopyText}"
                                             Visibility="{Binding CopyVisibility}"
                                             Click="OnCopyWarningFix"
                                             AutomationProperties.AutomationId="CommandCenterCopyWarningFixButton"
                                             Margin="0,8,0,0"
                                             HorizontalAlignment="Left"/>
                                 </StackPanel>
                             </Grid>
                         </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Port Diagnostics Section -->
            <StackPanel x:Name="PortDiagnosticsSection" AutomationProperties.AutomationId="CommandCenterPortDiagnosticsSection" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="PORT DIAGNOSTICS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <ItemsControl x:Name="PortDiagnosticsList" AutomationProperties.AutomationId="CommandCenterPortDiagnosticsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Purpose}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusText}" Grid.Column="2"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Permissions Section -->
            <StackPanel x:Name="PermissionsSection" AutomationProperties.AutomationId="CommandCenterPermissionsSection" Spacing="8">
                <TextBlock Text="PERMISSIONS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <ItemsControl x:Name="PermissionsList" AutomationProperties.AutomationId="CommandCenterPermissionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="Settings"
                                        Tag="{Binding SettingsUri}"
                                        Click="OnOpenPermissionSettings"
                                        AutomationProperties.AutomationId="CommandCenterOpenPermissionSettingsButton"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Usage Section -->
            <StackPanel x:Name="UsageSection" AutomationProperties.AutomationId="CommandCenterUsageSection" Spacing="8">
                <TextBlock x:Uid="StatusUsageHeader" Text="USAGE" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                
                <Grid ColumnSpacing="16" RowSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Uid="StatusCostLabel" Grid.Row="0" Grid.Column="0" Text="Cost (window):"/>
                    <TextBlock x:Name="TodayCostText" Grid.Row="0" Grid.Column="1" 
                               Text="$0.00" FontWeight="SemiBold"/>
                    
                    <TextBlock x:Uid="StatusRequestsLabel" Grid.Row="1" Grid.Column="0" Text="Requests / Tokens:"/>
                    <TextBlock x:Name="TodayRequestsText" Grid.Row="1" Grid.Column="1" 
                               Text="0 / 0" FontWeight="SemiBold"/>

                    <TextBlock x:Uid="StatusProvidersLabel" Grid.Row="2" Grid.Column="0" Text="Providers:"/>
                    <TextBlock x:Name="ProviderSummaryText" Grid.Row="2" Grid.Column="1"
                               Text="n/a" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>

            <!-- Sessions Section -->
            <StackPanel x:Name="SessionsSection" AutomationProperties.AutomationId="CommandCenterSessionsSection" Spacing="8">
                <TextBlock x:Uid="StatusSessionsHeader" Text="ACTIVE SESSIONS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                
                <ItemsControl x:Name="SessionsList" AutomationProperties.AutomationId="CommandCenterSessionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="💬" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Channel}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding LastMessage}" 
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock x:Name="NoSessionsText" x:Uid="StatusNoSessions" Text="No active sessions"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Channels Section -->
            <StackPanel x:Name="ChannelsSection" AutomationProperties.AutomationId="CommandCenterChannelsSection" Spacing="8">
                <TextBlock x:Uid="StatusChannelsHeader" Text="CHANNELS" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                
                <ItemsControl x:Name="ChannelsList" AutomationProperties.AutomationId="CommandCenterChannelsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusText}" Grid.Column="2"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Nodes Section -->
            <StackPanel x:Name="NodesSection" AutomationProperties.AutomationId="CommandCenterNodesSection" Spacing="8">
                <TextBlock Text="NODES" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="Bold"/>
                <ItemsControl x:Name="NodesList" AutomationProperties.AutomationId="CommandCenterNodesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" Margin="0,2" CornerRadius="4"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusIcon}" Grid.Column="0" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DetailText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CommandText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="NoNodesText" Text="No nodes reported"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Refresh Button -->
            <Button x:Name="RefreshButton" x:Uid="StatusRefreshButton" AutomationProperties.AutomationId="RefreshButton" Content="Refresh" Click="OnRefresh" HorizontalAlignment="Center"/>
            
        </StackPanel>
    </ScrollViewer>
</winex:WindowEx>

