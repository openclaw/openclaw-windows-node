<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="SessionsPage_TextBlock_10" Text="💬 Sessions" Style="{StaticResource TitleTextBlockStyle}"/>

            <InfoBar x:Uid="ConnectionWarning" x:Name="ConnectionWarning" Title="Not Connected"
                     Message="Connect to gateway to see live data"
                     Severity="Warning" IsOpen="True" IsClosable="False" Visibility="Collapsed"/>

            <!-- Session List -->
            <ListView x:Name="SessionListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,4">
                            <StackPanel Spacing="8">
                                <!-- Header row: key + age -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Key}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TimeAgo}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                </Grid>

                                <!-- Preview -->
                                <TextBlock Text="{Binding Preview}" MaxLines="2" TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextWrapping="Wrap"/>

                                <!-- Indicators row -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ThinkingBadge}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Visibility="{Binding ThinkingVisible}"/>
                                    <TextBlock Text="{Binding VerboseBadge}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Visibility="{Binding VerboseVisible}"/>
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="SessionsPage_Button_57" Content="Reset" Tag="{Binding Key}" Click="OnResetSession"
                                            Style="{StaticResource DefaultButtonStyle}" Padding="8,4"/>
                                    <Button x:Uid="SessionsPage_Button_59" Content="Compact" Tag="{Binding Key}" Click="OnCompactSession"
                                            Style="{StaticResource DefaultButtonStyle}" Padding="8,4"/>
                                    <Button x:Uid="SessionsPage_Button_61" Content="Delete" Tag="{Binding Key}" Click="OnDeleteSession"
                                            Foreground="IndianRed" Padding="8,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Spacing="8" HorizontalAlignment="Center" Margin="0,32,0,0">
                <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Uid="SessionsPage_TextBlock_73" Text="No active sessions"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Refresh -->
            <Button x:Uid="RefreshButton" x:Name="RefreshButton" Content="Refresh" HorizontalAlignment="Center"
                    Click="OnRefresh" Margin="0,8,0,0"/>

            <!-- Available Models -->
            <StackPanel x:Name="ModelsSection" Spacing="8" Visibility="Collapsed">
                <TextBlock x:Uid="SessionsPage_TextBlock_84" Text="🤖 Available Models" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0"/>
                <StackPanel x:Name="ModelsList" Spacing="4"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
