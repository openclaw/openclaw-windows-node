<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenClawTray.Pages.PermissionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock Text="🔐 Permissions" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <!-- Exec Policy -->
            <Expander x:Name="ExecPolicyExpander" IsExpanded="True"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Exec Policy" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4">
                    <TextBlock Text="Controls which commands the agent can execute on this node. Rules are matched against the full command line."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                    <ComboBox x:Name="DefaultActionCombo" Header="Default Action" Width="200"
                              SelectionChanged="OnDefaultActionChanged">
                        <ComboBoxItem Content="Deny" Tag="deny"/>
                        <ComboBoxItem Content="Allow" Tag="allow"/>
                        <ComboBoxItem Content="Ask" Tag="ask"/>
                    </ComboBox>

                    <TextBlock Text="Rules" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0"/>

                    <ListView x:Name="PolicyRulesList" SelectionMode="None" MaxHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Pattern}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center"
                                            Background="{Binding ActionBrush}">
                                        <TextBlock Text="{Binding Action}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <Button Grid.Column="2" Content="✕" Click="OnRemoveRule" Tag="{Binding Index}"
                                            Padding="4,2" MinWidth="0" Background="Transparent"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="NewRulePattern" PlaceholderText="Command pattern (e.g. echo *)" Width="250"/>
                        <ComboBox x:Name="NewRuleAction" Width="100" SelectedIndex="0">
                            <ComboBoxItem Content="allow"/>
                            <ComboBoxItem Content="deny"/>
                        </ComboBox>
                        <Button Content="Add Rule" Click="OnAddRule"/>
                    </StackPanel>

                    <Button x:Name="SaveExecPolicyButton" Content="Save Exec Policy" Click="OnSaveExecPolicy"
                            Style="{ThemeResource AccentButtonStyle}"/>
                </StackPanel>
            </Expander>

            <!-- Node Allowlist -->
            <Expander x:Name="AllowlistExpander"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Node Allowlist" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4">
                    <TextBlock Text="Commands allowed by the gateway for connected nodes. This list is read-only — edit via the Config page."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                    <TextBlock x:Name="AllowlistEmpty" Text="No allowlist data available. Connect to a gateway first."
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"/>

                    <ItemsRepeater x:Name="AllowlistRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </Expander>

            <!-- System Permissions -->
            <Expander x:Name="PermissionsExpander"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="System Permissions" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="4">
                    <TextBlock Text="System permissions for camera, microphone, and screen capture. These are managed by Windows Privacy settings."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="📷 Camera" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CameraPermStatus" Text="Unknown"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="🎤 Microphone" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MicPermStatus" Text="Unknown"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="🖥️ Screen Capture" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ScreenPermStatus" Text="Available"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <Button Content="Open Windows Privacy Settings" Click="OnOpenPrivacySettings"/>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
