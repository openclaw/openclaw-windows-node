<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.CapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="CapabilitiesPage_TextBlock_10" Text="🖥️ This Computer" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="HostnameText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <TextBlock x:Uid="CapabilitiesPage_TextBlock_15" Text="Device capabilities provided to agents via the gateway. Toggle what this computer can do."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" MaxWidth="500" Margin="0,0,0,8"/>

            <!-- Capability toggles -->
            <ItemsRepeater x:Name="CapabilityRepeater">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="220" MinItemHeight="60"
                                       MinColumnSpacing="12" MinRowSpacing="8"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>

            <!-- MCP Server -->
            <Border x:Name="McpCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_33" Text="Local MCP Server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_34" Text="Expose capabilities via HTTP for CLI tools and local integrations."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <ToggleSwitch x:Name="McpToggle" Toggled="OnMcpToggled"/>
                    <StackPanel x:Name="McpDetailsPanel" Spacing="6" Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="CapabilitiesPage_TextBlock_44" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock x:Name="McpEndpointText" Grid.Column="1" IsTextSelectionEnabled="True"
                                       VerticalAlignment="Center" FontFamily="Consolas"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="CopyMcpTokenButton" x:Name="CopyMcpTokenButton" Content="Copy Token" Click="OnCopyMcpToken"/>
                            <Button x:Uid="CopyMcpUrlButton" x:Name="CopyMcpUrlButton" Content="Copy URL" Click="OnCopyMcpUrl"/>
                        </StackPanel>
                        <TextBlock x:Name="McpStatusText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Node status -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="CapabilitiesPage_TextBlock_66" Text="Node Status" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse x:Name="NodeStatusDot" Width="10" Height="10"
                                 VerticalAlignment="Center" Fill="Gray"/>
                        <TextBlock x:Uid="NodeStatusText" x:Name="NodeStatusText" Text="Node mode disabled"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="NodeDetailsText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
