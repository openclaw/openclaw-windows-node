<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,24,24,12">
            <StackPanel Spacing="12" HorizontalAlignment="Stretch">

                <TextBlock Text="⚙️ Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

                <!-- Connection -->
                <Expander x:Name="ConnectionExpander" IsExpanded="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.AutomationId="ConnectionExpander">
                    <Expander.Header>
                        <TextBlock Text="Connection" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Expander.Header>
                    <StackPanel Spacing="12" Padding="4">
                        <ToggleSwitch x:Name="UseSshTunnelToggle" Header="Connect through SSH tunnel"
                                      Toggled="OnSshTunnelToggled"
                                      AutomationProperties.AutomationId="SettingsPageSshToggle"/>
                        <StackPanel x:Name="SshTunnelDetailsPanel" Spacing="8" Visibility="Collapsed">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshTunnelUserTextBox" Grid.Column="0" Header="SSH User" PlaceholderText="user"/>
                            <TextBox x:Name="SshTunnelHostTextBox" Grid.Column="1" Header="SSH Host" PlaceholderText="machine-name or IP"/>
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SshTunnelRemotePortTextBox" Grid.Column="0" Header="Remote Gateway Port" PlaceholderText="18789"/>
                            <TextBox x:Name="SshTunnelLocalPortTextBox" Grid.Column="1" Header="Local Forward Port" PlaceholderText="18789"/>
                        </Grid>
                    </StackPanel>
                    <TextBox x:Name="GatewayUrlTextBox" Header="Gateway URL"
                                 PlaceholderText="ws://localhost:18789 or https://host.tailnet.ts.net"
                                 AutomationProperties.AutomationId="SettingsPageGatewayUrl"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="TokenTextBox" Header="Token"
                                     PlaceholderText="Your API token" Width="300"
                                     AutomationProperties.AutomationId="SettingsPageToken"/>
                            <Button x:Name="TestConnectionButton" Content="Test" VerticalAlignment="Bottom"
                                    Click="OnTestConnection"
                                    AutomationProperties.AutomationId="SettingsPageTestButton"/>
                        </StackPanel>
                        <TextBlock x:Name="ConnectionStatusLabel"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Expander>

                <!-- Startup -->
                <Expander x:Name="StartupExpander"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.AutomationId="StartupExpander">
                    <Expander.Header>
                        <TextBlock Text="Startup" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Expander.Header>
                    <StackPanel Spacing="12" Padding="4">
                        <ToggleSwitch x:Name="AutoStartToggle" Header="Start automatically with Windows"
                                      AutomationProperties.AutomationId="SettingsPageAutoStart"/>
                        <ToggleSwitch x:Name="GlobalHotkeyToggle" Header="Global hotkey (Ctrl+Alt+Shift+C → Quick Send)"
                                      AutomationProperties.AutomationId="SettingsPageHotkey"/>
                    </StackPanel>
                </Expander>

                <!-- Notifications -->
                <Expander x:Name="NotificationsExpander"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.AutomationId="NotificationsExpander">
                    <Expander.Header>
                        <TextBlock Text="Notifications" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Expander.Header>
                    <StackPanel Spacing="12" Padding="4">
                        <ToggleSwitch x:Name="NotificationsToggle" Header="Show notifications"
                                      AutomationProperties.AutomationId="SettingsPageNotifications"/>
                        <ComboBox x:Name="NotificationSoundComboBox" Header="Sound" Width="200"
                                  AutomationProperties.AutomationId="SettingsPageSound">
                            <ComboBoxItem Content="Default" Tag="Default"/>
                            <ComboBoxItem Content="None" Tag="None"/>
                            <ComboBoxItem Content="Subtle" Tag="Subtle"/>
                        </ComboBox>
                        <TextBlock Text="Show notifications for:"
                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,4,0,0"/>
                        <StackPanel Spacing="4">
                            <CheckBox x:Name="NotifyHealthCb" Content="Health alerts"
                                      AutomationProperties.AutomationId="SettingsPageNotifyHealth"/>
                            <CheckBox x:Name="NotifyUrgentCb" Content="Urgent messages"
                                      AutomationProperties.AutomationId="SettingsPageNotifyUrgent"/>
                            <CheckBox x:Name="NotifyReminderCb" Content="Reminders"
                                      AutomationProperties.AutomationId="SettingsPageNotifyReminder"/>
                            <CheckBox x:Name="NotifyEmailCb" Content="Email summaries"
                                      AutomationProperties.AutomationId="SettingsPageNotifyEmail"/>
                            <CheckBox x:Name="NotifyCalendarCb" Content="Calendar events"
                                      AutomationProperties.AutomationId="SettingsPageNotifyCalendar"/>
                            <CheckBox x:Name="NotifyBuildCb" Content="Build notifications"
                                      AutomationProperties.AutomationId="SettingsPageNotifyBuild"/>
                            <CheckBox x:Name="NotifyStockCb" Content="Stock alerts"
                                      AutomationProperties.AutomationId="SettingsPageNotifyStock"/>
                            <CheckBox x:Name="NotifyInfoCb" Content="Info messages"
                                      AutomationProperties.AutomationId="SettingsPageNotifyInfo"/>
                        </StackPanel>
                        <Button x:Name="TestNotificationButton" Content="Send Test Notification" Click="OnTestNotification"/>
                    </StackPanel>
                </Expander>

                <!-- Advanced -->
                <Expander x:Name="AdvancedExpander"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          AutomationProperties.AutomationId="AdvancedExpander">
                    <Expander.Header>
                        <TextBlock Text="Advanced" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </Expander.Header>
                    <StackPanel Spacing="8" Padding="4">
                        <!-- Node Mode moved to Capabilities page -->
                    </StackPanel>
                </Expander>



            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="24,16">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Width="80" Click="OnCancel"
                        AutomationProperties.AutomationId="SettingsPageCancel"/>
                <Button x:Name="SaveButton" Content="Save" Width="80" Click="OnSave"
                        Style="{ThemeResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="SettingsPageSave"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
