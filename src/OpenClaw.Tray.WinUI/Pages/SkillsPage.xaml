<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="SkillsPage_TextBlock_10" Text="🧩 Skills" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Agent Filter -->
            <ComboBox x:Uid="AgentFilterCombo" x:Name="AgentFilterCombo" Header="Agent" MinWidth="200"
                      SelectionChanged="OnAgentFilterChanged">
                <ComboBoxItem x:Uid="SkillsPage_ComboBoxItem_15" Content="All Agents" Tag="" IsSelected="True"/>
            </ComboBox>

            <!-- Skills List -->
            <ListView x:Name="SkillsList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Name + Version + Status -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Version}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{Binding StatusBackground}">
                                        <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                   Foreground="White"/>
                                    </Border>
                                </StackPanel>

                                <!-- Row 0: Action buttons -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Content="{Binding ActionLabel}" Tag="{Binding Id}"
                                            Click="OnSkillActionClick"/>
                                </StackPanel>

                                <!-- Row 1: Description -->
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" MaxLines="2" Margin="0,6,0,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState" Visibility="Visible"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                        Margin="0,32,0,0">
                <TextBlock Text="🧩" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Uid="SkillsPage_TextBlock_81" Text="No skills installed"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Marketplace Link -->
            <HyperlinkButton x:Uid="MarketplaceLink" x:Name="MarketplaceLink" Content="Browse Skills Marketplace →"
                             Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Page>
