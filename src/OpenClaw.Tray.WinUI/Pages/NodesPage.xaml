<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.NodesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="NodesPage_TextBlock_10" Text="🖥️ Nodes" Style="{StaticResource TitleTextBlockStyle}"/>

            <InfoBar x:Uid="ConnectionWarning" x:Name="ConnectionWarning" Title="Not Connected"
                     Message="Connect to gateway to see live data"
                     Severity="Warning" IsOpen="True" IsClosable="False" Visibility="Collapsed"/>

            <!-- Node Cards -->
            <StackPanel x:Name="NodesList" Spacing="8"/>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Spacing="8" HorizontalAlignment="Center" Margin="0,32,0,0">
                <TextBlock Text="🖥️" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Uid="NodesPage_TextBlock_22" Text="No nodes connected"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Pairing Requests -->
            <StackPanel x:Name="PairingSection" Spacing="8" Visibility="Collapsed">
                <TextBlock x:Uid="NodesPage_TextBlock_29" Text="🔗 Pending Pairing Requests" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
                <StackPanel x:Name="PairingList" Spacing="4"/>
            </StackPanel>

            <!-- Device Pairing Requests -->
            <StackPanel x:Name="DevicePairingSection" Spacing="8" Visibility="Collapsed">
                <TextBlock x:Uid="NodesPage_TextBlock_35" Text="📱 Pending Device Pairing" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
                <StackPanel x:Name="DevicePairingList" Spacing="4"/>
            </StackPanel>

            <!-- Connected Clients (presence data) -->
            <StackPanel x:Name="PresenceSection" Spacing="8" Visibility="Collapsed">
                <TextBlock x:Uid="NodesPage_TextBlock_41" Text="🌐 Connected Clients" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0"/>
                <StackPanel x:Name="PresenceList" Spacing="4"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
