<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.AgentEventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Agent Events" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="CountText" Text="(0)" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Filter bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,0,0,16">
            <ToggleButton x:Name="FilterAllButton" Content="All" Tag="all" IsChecked="True"
                          Click="OnFilterClick"/>
            <ToggleButton Content="Lifecycle" Tag="lifecycle" Click="OnFilterClick"/>
            <ToggleButton Content="Tool" Tag="tool" Click="OnFilterClick"/>
            <ToggleButton Content="Assistant" Tag="assistant" Click="OnFilterClick"/>
            <ToggleButton Content="Error" Tag="error" Click="OnFilterClick"/>
            <ToggleButton Content="Plan" Tag="plan" Click="OnFilterClick"/>
            <ToggleButton Content="Approval" Tag="approval" Click="OnFilterClick"/>
        </StackPanel>

        <!-- Events list -->
        <ListView x:Name="EventsList" Grid.Row="2"
                  SelectionMode="None"
                  Visibility="Collapsed">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" Margin="0,2" CornerRadius="4"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: stream badge + runId + timestamp -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                            <Border x:Name="StreamBadge" CornerRadius="4" Padding="6,2"
                                    Background="{ThemeResource SystemFillColorNeutralBrush}">
                                <TextBlock Text="{Binding StreamUpper}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="{Binding RunId}" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding FormattedTime}" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <!-- Data JSON -->
                        <TextBlock Grid.Row="1" Text="{Binding DataJson}" TextWrapping="Wrap"
                                   MaxLines="8" FontFamily="Consolas" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0" IsTextSelectionEnabled="True"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="2"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="🤖" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="No agent events yet"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Real-time agent events (tool calls, responses, errors) will appear here as agents run."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="320"/>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button x:Name="ClearButton" Content="Clear" Click="OnClear"/>
        </StackPanel>
    </Grid>
</Page>
