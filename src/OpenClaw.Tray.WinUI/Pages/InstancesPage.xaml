<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenClawTray.Pages.InstancesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" HorizontalAlignment="Stretch">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Uid="InstancesPage_Title"
                               Text="Instances"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock x:Uid="InstancesPage_Subtitle"
                               Text="Latest presence beacons from OpenClaw nodes."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="RefreshButton"
                        Grid.Column="1"
                        Click="OnRefreshClicked"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Grid Width="14" Height="14">
                            <FontIcon x:Name="RefreshIcon"
                                      Glyph="&#xE72C;"
                                      FontSize="14"/>
                            <ProgressRing x:Name="RefreshSpinner"
                                          IsActive="False"
                                          Width="14"
                                          Height="14"
                                          Visibility="Collapsed"/>
                        </Grid>
                        <TextBlock x:Uid="InstancesPage_RefreshLabel" Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <InfoBar x:Uid="InstancesPage_ConnectionWarning"
                     x:Name="ConnectionWarning"
                     Title="Not connected"
                     Message="Connect to a gateway to see live instance data."
                     Severity="Warning"
                     IsOpen="True"
                     IsClosable="False"
                     Visibility="Collapsed"/>

            <StackPanel x:Name="EmptyState"
                        Spacing="8"
                        HorizontalAlignment="Center"
                        Padding="0,32"
                        Visibility="Collapsed">
                <FontIcon Glyph="&#xE977;"
                          FontSize="40"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock x:Uid="InstancesPage_EmptyTitle"
                           Text="No instances reported yet."
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <StackPanel x:Name="InstancesList" Spacing="8"/>

        </StackPanel>
    </ScrollViewer>
</Page>
