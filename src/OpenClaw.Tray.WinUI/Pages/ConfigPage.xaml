<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Controls">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <TextBlock Text="⚙️ Config" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <Button x:Name="RefreshButton" Click="OnRefresh" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- TreeView + Detail Panel (primary layout) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,12,0">
                <TreeView x:Name="ConfigTree"
                          SelectionMode="Single"
                          ItemInvoked="OnTreeItemInvoked"
                          Padding="4"/>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Padding="16,12" Spacing="4"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                        <TextBlock x:Name="DetailPath" Text="Select a config key"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="DetailType" Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Padding="16,8">
                        <StackPanel x:Name="DetailPanel" Spacing="8">
                            <TextBlock x:Name="DetailPlaceholder"
                                       Text="Click a config key in the tree to view and edit its value."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Hidden schema editor (used internally for field rendering) -->
        <local:SchemaConfigEditor x:Name="SchemaEditor" Visibility="Collapsed"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Padding="0,8,0,0">
            <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button x:Name="SaveButton" Content="Save Changes" Style="{ThemeResource AccentButtonStyle}" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Page>
